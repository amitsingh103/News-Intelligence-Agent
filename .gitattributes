# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.py text diff=python
*.md text
*.txt text
*.yml text
*.yaml text
*.json text
*.toml text
*.cfg text
*.ini text

# Denote binary files
*.db binary
*.sqlite binary
*.sqlite3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
